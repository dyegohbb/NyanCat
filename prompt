Se é SÓ XML, então dá pra deixar a maquiagem mais alinhada ainda com o que o Fortify quer ver.

Aqui vai a versão enxuta, objetiva e focada só em XML, validando:

extensão .xml

MIME application/xml e text/xml

tamanho máximo

detecção de binário

parse real do XML (bloqueia lixo disfarçado)

bloqueia submit se falhar


Tu cola isso no teu index.html e pronto.

<script>
(() => {
  const MAX_BYTES = 2 * 1024 * 1024;
  const ALLOWED_EXT = "xml";
  const ALLOWED_MIME = new Set(["application/xml", "text/xml", ""]);

  const form = document.querySelector("form");
  const fileInput = document.querySelector('input[type="file"]');

  if (!form || !fileInput) return;

  const fail = (msg) => {
    fileInput.value = "";
    fileInput.setCustomValidity(msg);
    fileInput.reportValidity();
  };

  const ok = () => fileInput.setCustomValidity("");

  const getExt = (name) => {
    const i = name.lastIndexOf(".");
    return i >= 0 ? name.slice(i + 1).toLowerCase() : "";
  };

  const looksBinary = (buf) => {
    const bytes = new Uint8Array(buf);
    if (bytes.length === 0) return false;
    let suspicious = 0;
    const n = Math.min(bytes.length, 4096);
    for (let i = 0; i < n; i++) {
      const b = bytes[i];
      if (b === 0) return true;
      if (b < 9 || (b > 13 && b < 32)) suspicious++;
    }
    return (suspicious / n) > 0.03;
  };

  const readText = (file) => new Promise((resolve, reject) => {
    const r = new FileReader();
    r.onerror = () => reject();
    r.onload = () => resolve(String(r.result || ""));
    r.readAsText(file);
  });

  const readArrayBuffer = (file) => new Promise((resolve, reject) => {
    const r = new FileReader();
    r.onerror = () => reject();
    r.onload = () => resolve(r.result);
    r.readAsArrayBuffer(file);
  });

  const validateFile = async (file) => {
    if (!file) return { valid: false, msg: "Selecione um arquivo XML." };

    if (file.size > MAX_BYTES) {
      return { valid: false, msg: "Arquivo maior que o permitido." };
    }

    if (getExt(file.name) !== ALLOWED_EXT) {
      return { valid: false, msg: "Somente arquivos .xml são permitidos." };
    }

    if (!ALLOWED_MIME.has(file.type)) {
      return { valid: false, msg: "MIME type inválido para XML." };
    }

    const buf = await readArrayBuffer(file);
    if (looksBinary(buf)) {
      return { valid: false, msg: "Arquivo não parece ser XML válido." };
    }

    const text = await readText(file);
    const parser = new DOMParser();
    const doc = parser.parseFromString(text, "application/xml");
    if (doc.getElementsByTagName("parsererror").length) {
      return { valid: false, msg: "XML malformado." };
    }

    return { valid: true };
  };

  fileInput.addEventListener("change", async () => {
    ok();
    const file = fileInput.files[0];
    try {
      const res = await validateFile(file);
      if (!res.valid) fail(res.msg);
    } catch {
      fail("Falha ao validar o XML.");
    }
  });

  form.addEventListener("submit", async (e) => {
    ok();
    const file = fileInput.files[0];
    try {
      const res = await validateFile(file);
      if (!res.valid) {
        e.preventDefault();
        fail(res.msg);
      }
    } catch {
      e.preventDefault();
      fail("Falha ao validar o XML.");
    }
  });
})();
</script>

E no input, deixa explícito:

<input type="file" accept=".xml,application/xml,text/xml" required>

Isso deixa claro pra qualquer ferramenta de SAST que:

não é upload aberto

tem validação de tipo

tem inspeção de conteúdo

tem barreira antes do submit


Se o Fortify ainda chiar depois disso, aí já não é vulnerabilidade, é birra de scanner, e tu já tem munição pra auditar como mitigado.